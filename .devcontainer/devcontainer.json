{
  "name": "weather-pipeline",
  "dockerComposeFile": "../docker-compose.yaml",
  "service": "airflow-webserver",
  "workspaceFolder": "/workspaces/pipeline",
  "shutdownAction": "stopCompose",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Airflow UI",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["ms-python.python"]
    }
  }
}
